# BigBrain — environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored and must never be committed.

# ─── Neon (Postgres) ──────────────────────────────────────────────────────────
# Get from: Neon console → your project → Connection string
DATABASE_URL=

# ─── FalkorDB ─────────────────────────────────────────────────────────────────
# Get from: Fly.io app → your FalkorDB instance
FALKORDB_URL=
FALKORDB_PASSWORD=

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Note: Claude Max subscription does NOT include API access — billed separately
ANTHROPIC_API_KEY=

# ─── Auth.js (NextAuth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── Vercel Blob (file storage) ───────────────────────────────────────────────
# Populated automatically by Vercel when Blob storage is connected to the project.
# For local development, get from: Vercel dashboard → Storage → your Blob store → .env.local
BLOB_READ_WRITE_TOKEN=

# ─── Cron secret ──────────────────────────────────────────────────────────────
# Authenticates Vercel cron triggers (and manual admin runs).
# Generate with: openssl rand -base64 32
# Set the SAME value in Vercel project env so scheduled cron jobs authenticate.
CRON_SECRET=
